<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Hero Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱 EcoSort AI"
                    android:textColor="@color/primary_green"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="AI-Powered Sustainable Waste Intelligence"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Dispose smarter. Recycle better. Protect the planet."
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Eco Tip Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌍 Eco Insights"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEcoTip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="🌱 Small sustainable actions create big impact."/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Actions -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Quick Actions"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 Battery"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlastic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="♻️ Plastic"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEWaste"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💻 E-Waste"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍃 Compost"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp"/>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Search -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                android:hint="Ask about batteries, plastic, e-waste or compost"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAsk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="🧠 Generate Recommendation"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <!-- Recommendation Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Disposal Recommendation"
                    android:textColor="@color/primary_green"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Verified Source"
                    android:textColor="@color/secondary_green"
                    android:textStyle="bold"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/confidenceBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:indicatorDirectionLinear="startToEnd"
                    android:visibility="gone"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="🌱🧠 EcoSort AI is ready.\n\nAsk a sustainability question or scan an item to receive personalized disposal guidance."
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:lineSpacingExtra="6dp"
                    android:paddingTop="6dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- History Button -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="📚 Query History"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_margin="20dp"
            android:contentDescription="Scan Waste"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@android:color/white"
            app:backgroundTint="@color/primary_green"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            android:text="EcoSort AI v1.0\nAndroid • Spring Boot • Mistral 7B"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>
